{
  "name": "insaatborsam",
  "version": "0.0.0",
  "private": true,
  "description": "İnşaat Borsam — AI destekli inşaat tedarik borsası monorepo",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "theme:sync": "tsx scripts/sync-theme.ts",
    "predev": "pnpm theme:sync",
    "prebuild": "pnpm theme:sync",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev-web": "turbo run dev --filter=@insaatborsam/web",
    "dev-buyer": "turbo run dev --filter=@insaatborsam/buyer",
    "dev-seller": "turbo run dev --filter=@insaatborsam/seller",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:types": "echo 'TODO Sprint 1: supabase gen types typescript --linked > packages/database/src/types.ts'"
  },
  "devDependencies": {
    "tsx": "^4.22.2",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}
